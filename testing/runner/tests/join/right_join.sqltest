@database :memory:

# Tests for RIGHT JOIN support (NLJ path).

# ============================================================
# Basic 2-table RIGHT JOIN
# ============================================================

test right-join-basic {
    CREATE TABLE t1(a, b);
    CREATE TABLE t2(c, d);
    INSERT INTO t1 VALUES (1, 'x'), (2, 'y');
    INSERT INTO t2 VALUES (1, 'a'), (2, 'b'), (3, 'c');
    SELECT t1.a, t1.b, t2.c, t2.d FROM t1 RIGHT JOIN t2 ON t1.a = t2.c ORDER BY t2.c;
}
expect {
    1|x|1|a
    2|y|2|b
    ||3|c
}

test right-join-no-matches {
    CREATE TABLE t1(a, b);
    CREATE TABLE t2(c, d);
    INSERT INTO t1 VALUES (10, 'x'), (20, 'y');
    INSERT INTO t2 VALUES (1, 'a'), (2, 'b');
    SELECT t1.a, t1.b, t2.c, t2.d FROM t1 RIGHT JOIN t2 ON t1.a = t2.c ORDER BY t2.c;
}
expect {
    ||1|a
    ||2|b
}

test right-join-all-match {
    CREATE TABLE t1(a, b);
    CREATE TABLE t2(c, d);
    INSERT INTO t1 VALUES (1, 'x'), (2, 'y');
    INSERT INTO t2 VALUES (1, 'a'), (2, 'b');
    SELECT t1.a, t1.b, t2.c, t2.d FROM t1 RIGHT JOIN t2 ON t1.a = t2.c ORDER BY t2.c;
}
expect {
    1|x|1|a
    2|y|2|b
}

# ============================================================
# 3-table queries with RIGHT JOIN
# ============================================================

test right-join-3table-inner-then-right {
    CREATE TABLE t1(a INTEGER);
    CREATE TABLE t2(b INTEGER);
    CREATE TABLE t3(c INTEGER);
    INSERT INTO t1 VALUES (1), (2);
    INSERT INTO t2 VALUES (1), (2);
    INSERT INTO t3 VALUES (1), (2), (3);
    SELECT t1.a, t2.b, t3.c FROM t1 JOIN t2 ON t1.a = t2.b RIGHT JOIN t3 ON t2.b = t3.c ORDER BY t3.c;
}
expect {
    1|1|1
    2|2|2
    ||3
}

test right-join-3table-right-then-inner {
    CREATE TABLE t1(a INTEGER);
    CREATE TABLE t2(b INTEGER);
    CREATE TABLE t3(c INTEGER);
    INSERT INTO t1 VALUES (1), (2), (3);
    INSERT INTO t2 VALUES (2), (3);
    INSERT INTO t3 VALUES (2), (3);
    SELECT t1.a, t2.b, t3.c FROM t1 RIGHT JOIN t2 ON t1.a = t2.b JOIN t3 ON t2.b = t3.c ORDER BY t2.b;
}
expect {
    2|2|2
    3|3|3
}

# ============================================================
# Empty tables
# ============================================================

test right-join-empty-left {
    CREATE TABLE t1(a, b);
    CREATE TABLE t2(c, d);
    INSERT INTO t2 VALUES (1, 'a'), (2, 'b');
    SELECT t1.a, t1.b, t2.c, t2.d FROM t1 RIGHT JOIN t2 ON t1.a = t2.c ORDER BY t2.c;
}
expect {
    ||1|a
    ||2|b
}

test right-join-empty-right {
    CREATE TABLE t1(a, b);
    CREATE TABLE t2(c, d);
    INSERT INTO t1 VALUES (1, 'x'), (2, 'y');
    SELECT t1.a, t1.b, t2.c, t2.d FROM t1 RIGHT JOIN t2 ON t1.a = t2.c ORDER BY t1.a;
}
expect {
}

# ============================================================
# NULL join keys
# ============================================================

test right-join-null-keys {
    CREATE TABLE t1(a, b);
    CREATE TABLE t2(c, d);
    INSERT INTO t1 VALUES (1, 'x'), (NULL, 'y');
    INSERT INTO t2 VALUES (1, 'a'), (NULL, 'b'), (3, 'c');
    SELECT t1.a, t1.b, t2.c, t2.d FROM t1 RIGHT JOIN t2 ON t1.a = t2.c ORDER BY t2.c, t2.d;
}
expect {
    |||b
    1|x|1|a
    ||3|c
}

# ============================================================
# WHERE on left-side columns
# ============================================================

test right-join-where-left-col {
    CREATE TABLE t1(a, b);
    CREATE TABLE t2(c, d);
    INSERT INTO t1 VALUES (1, 'x'), (2, 'y');
    INSERT INTO t2 VALUES (1, 'a'), (2, 'b'), (3, 'c');
    SELECT t1.a, t1.b, t2.c, t2.d FROM t1 RIGHT JOIN t2 ON t1.a = t2.c WHERE t1.a IS NOT NULL ORDER BY t2.c;
}
expect {
    1|x|1|a
    2|y|2|b
}

# ============================================================
# WHERE on right-side columns
# ============================================================

test right-join-where-right-col {
    CREATE TABLE t1(a, b);
    CREATE TABLE t2(c, d);
    INSERT INTO t1 VALUES (1, 'x'), (2, 'y');
    INSERT INTO t2 VALUES (1, 'a'), (2, 'b'), (3, 'c');
    SELECT t1.a, t1.b, t2.c, t2.d FROM t1 RIGHT JOIN t2 ON t1.a = t2.c WHERE t2.c > 1 ORDER BY t2.c;
}
expect {
    2|y|2|b
    ||3|c
}

# ============================================================
# ORDER BY
# ============================================================

test right-join-order-by {
    CREATE TABLE t1(a, b);
    CREATE TABLE t2(c, d);
    INSERT INTO t1 VALUES (1, 'x');
    INSERT INTO t2 VALUES (1, 'a'), (2, 'b'), (3, 'c');
    SELECT t1.a, t2.c, t2.d FROM t1 RIGHT JOIN t2 ON t1.a = t2.c ORDER BY t2.c DESC;
}
expect {
    |3|c
    |2|b
    1|1|a
}

# ============================================================
# GROUP BY / COUNT
# ============================================================

test right-join-group-by-count {
    CREATE TABLE t1(a INTEGER);
    CREATE TABLE t2(c INTEGER);
    INSERT INTO t1 VALUES (1), (2);
    INSERT INTO t2 VALUES (1), (2), (3), (3);
    SELECT t2.c, COUNT(t1.a) FROM t1 RIGHT JOIN t2 ON t1.a = t2.c GROUP BY t2.c ORDER BY t2.c;
}
expect {
    1|1
    2|1
    3|0
}

# ============================================================
# Duplicate keys
# ============================================================

test right-join-duplicate-keys {
    CREATE TABLE t1(a, b);
    CREATE TABLE t2(c, d);
    INSERT INTO t1 VALUES (1, 'x'), (1, 'y'), (2, 'z');
    INSERT INTO t2 VALUES (1, 'a'), (2, 'b'), (3, 'c');
    SELECT t1.a, t1.b, t2.c, t2.d FROM t1 RIGHT JOIN t2 ON t1.a = t2.c ORDER BY t2.c, t1.b;
}
expect {
    1|x|1|a
    1|y|1|a
    2|z|2|b
    ||3|c
}
